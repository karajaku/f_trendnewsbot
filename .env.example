# f_trendnewsbot 환경변수 예시 (requirements §8, ADR-003)
# 이 파일은 git tracked. 실제 값은 .env(gitignored) 또는 GitHub Actions Secrets/Variables 에 저장.
# 시크릿 평문을 .env.example 에 넣지 말 것 — placeholder 만 사용.

# Anthropic Claude API 인증 키 (summarizer 가 사용)
ANTHROPIC_API_KEY=<your_anthropic_key>

# 텔레그램 Bot API 인증 토큰 (BotFather 발급, 형태 `123456:ABC-DEF...`)
TELEGRAM_BOT_TOKEN=<bot_token_from_BotFather>

# 직원 다이제스트 단톡방 chat ID (음수 정수, 예: -1001234567890)
TELEGRAM_CHAT_ID=<negative_int>

# 운영자 alert 전용 chat ID (실패 시 봇이 운영자에게 알림 보낼 chat)
OPS_ALERT_CHAT_ID=<int>

# Pages base URL — 텔레그램 메시지·로그에서 사용
PAGES_BASE_URL=https://<owner>.github.io/f_trendnewsbot

# 사용할 Claude 모델 ID. deprecated 시 코드 변경 없이 교체.
CLAUDE_MODEL_ID=claude-haiku-4-5-20251001

# (참고) GITHUB_TOKEN 은 GitHub Actions 가 자동 주입 — 로컬·.env 에 등록 불필요.
